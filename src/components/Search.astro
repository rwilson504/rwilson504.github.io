---
/**
 * Search.astro - Pagefind-powered static-site search.
 *
 * Renders a search icon button. When clicked (or `/` pressed), opens a
 * full-screen modal with Pagefind's prebuilt UI. The Pagefind index is
 * generated by `pagefind --site dist` after `astro build`, so it's only
 * present in production builds (the dev server will surface a console
 * warning the first time you open the modal, which is expected).
 */
---

<button
  id="search-trigger"
  class="search-trigger"
  type="button"
  aria-label="Search (press / to open)"
  title="Search (/)"
>
  <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true">
    <path
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      d="M9 3a6 6 0 1 0 0 12 6 6 0 0 0 0-12zM13.5 13.5L17 17"
    ></path>
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-kbd">/</kbd>
</button>

<dialog id="search-dialog" class="search-dialog" aria-label="Search the site">
  <div class="search-dialog-inner">
    <button
      class="search-close"
      type="button"
      aria-label="Close search"
      data-close-search
    >&times;</button>
    <div id="pagefind-search"></div>
  </div>
</dialog>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script>
  // Lazy-load Pagefind UI when the user first opens the search.
  // Note: /pagefind/pagefind-ui.js is an IIFE (not an ES module). It attaches
  // `window.PagefindUI` as a side effect, so we inject it as a <script> tag
  // rather than using dynamic import().
  let initialized = false;

  const trigger = document.getElementById("search-trigger");
  const dialog = document.getElementById("search-dialog") as HTMLDialogElement | null;
  const mount = document.getElementById("pagefind-search");

  function loadPagefindScript(): Promise<void> {
    return new Promise((resolve, reject) => {
      if ((window as any).PagefindUI) {
        resolve();
        return;
      }
      const s = document.createElement("script");
      s.src = "/pagefind/pagefind-ui.js";
      s.async = true;
      s.onload = () => resolve();
      s.onerror = () => reject(new Error("Failed to load /pagefind/pagefind-ui.js"));
      document.head.appendChild(s);
    });
  }

  async function initPagefind() {
    if (initialized || !mount) return;
    initialized = true;
    try {
      await loadPagefindScript();
      const PagefindUI = (window as any).PagefindUI;
      if (!PagefindUI) {
        throw new Error("window.PagefindUI not defined after script load");
      }
      // eslint-disable-next-line no-new
      new PagefindUI({
        element: "#pagefind-search",
        showSubResults: true,
        showImages: false,
        excerptLength: 30,
        resetStyles: false,
      });
    } catch (err) {
      console.warn("[Search] failed to load Pagefind UI", err);
      initialized = false; // allow a retry next time
      if (mount) {
        mount.innerHTML =
          '<p style="color:#888;padding:1rem">Search index not available. Try the production site.</p>';
      }
    }
  }

  function openDialog() {
    if (!dialog) return;
    void initPagefind();
    if (typeof dialog.showModal === "function") {
      dialog.showModal();
    } else {
      dialog.setAttribute("open", "");
    }
    // Focus the input shortly after Pagefind mounts.
    setTimeout(() => {
      const input = dialog.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      input?.focus();
    }, 60);
  }

  function closeDialog() {
    if (!dialog) return;
    if (typeof dialog.close === "function") dialog.close();
    else dialog.removeAttribute("open");
  }

  trigger?.addEventListener("click", openDialog);

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    const target = e.target as HTMLElement | null;
    const tag = target?.tagName;
    const inField =
      tag === "INPUT" || tag === "TEXTAREA" || target?.isContentEditable;
    if (e.key === "/" && !inField) {
      e.preventDefault();
      openDialog();
    }
    if (e.key === "Escape" && dialog?.open) {
      closeDialog();
    }
  });

  // Click outside the inner card or on the close button = close.
  dialog?.addEventListener("click", (e) => {
    const t = e.target as HTMLElement;
    if (t === dialog || t.dataset.closeSearch !== undefined) {
      closeDialog();
    }
  });
</script>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    border-radius: 999px;
    padding: 0.35em 0.8em 0.35em 0.7em;
    font: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }
  .search-trigger:hover {
    border-color: var(--color-accent);
    color: var(--color-fg);
  }
  .search-trigger svg {
    flex-shrink: 0;
  }
  .search-trigger-label {
    margin-right: 0.2em;
  }
  .search-kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0 0.35em;
    line-height: 1.4;
    color: var(--color-muted);
  }

  @media (max-width: 560px) {
    .search-trigger-label,
    .search-kbd {
      display: none;
    }
    .search-trigger {
      padding: 0.4em;
      border-radius: 50%;
    }
  }

  .search-dialog {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }
  .search-dialog-inner {
    position: relative;
    max-width: 720px;
    max-height: 84vh;
    margin: 8vh auto 0;
    padding: 1.5rem 1.5rem 1.5rem 1.5rem;
    background: var(--color-bg);
    color: var(--color-fg);
    border-radius: 14px;
    border: 1px solid var(--color-border);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.2);
    overflow-x: hidden;
    overflow-y: auto;
  }
  .search-close {
    position: sticky;
    top: 0;
    float: right;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-muted);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    margin-bottom: -32px;
    z-index: 2;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .search-close:hover {
    color: var(--color-fg);
    border-color: var(--color-accent);
  }

  /* Tweak Pagefind UI to match the site theme. */
  :global(#pagefind-search) {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-fg);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-code-bg);
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-font: var(--font-sans);
  }

  /* Pagefind's stylesheet hardcodes text color on the input and result
     bodies, so the CSS variables above don't reach them. Force them to
     use our theme tokens so dark-mode users can actually read what they
     typed. */
  :global(#pagefind-search .pagefind-ui__search-input) {
    color: var(--color-fg) !important;
    background: var(--color-bg) !important;
    border-color: var(--color-border) !important;
  }
  :global(#pagefind-search .pagefind-ui__search-input::placeholder) {
    color: var(--color-muted) !important;
  }
  :global(#pagefind-search .pagefind-ui__search-clear) {
    color: var(--color-fg) !important;
    background: var(--color-code-bg) !important;
    border: 1px solid var(--color-border) !important;
    border-radius: 8px !important;
    padding: 0.35rem 0.7rem !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
    cursor: pointer !important;
    transition: border-color 0.15s ease, color 0.15s ease !important;
  }
  :global(#pagefind-search .pagefind-ui__search-clear:hover) {
    border-color: var(--color-accent) !important;
    color: var(--color-accent) !important;
  }
  /* Give the search input some right padding so it never tucks under
     the close X button in the top-right corner of the modal. */
  :global(#pagefind-search .pagefind-ui__form) {
    margin-right: 2.5rem !important;
  }
  :global(#pagefind-search .pagefind-ui__result-title a),
  :global(#pagefind-search .pagefind-ui__result-link) {
    color: var(--color-fg) !important;
  }
  :global(#pagefind-search .pagefind-ui__result-title a:hover),
  :global(#pagefind-search .pagefind-ui__result-link:hover) {
    color: var(--color-accent) !important;
  }
  :global(#pagefind-search .pagefind-ui__result-excerpt) {
    color: var(--color-muted) !important;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  /* Any pre/code/inline-code from the indexed body should wrap rather
     than overflow the modal (we saw a long base64 blob blow out the
     width). */
  :global(#pagefind-search pre),
  :global(#pagefind-search code),
  :global(#pagefind-search .pagefind-ui__result) {
    overflow-wrap: anywhere;
    word-break: break-word;
    white-space: normal;
    max-width: 100%;
  }
  :global(#pagefind-search .pagefind-ui__result-tags),
  :global(#pagefind-search .pagefind-ui__message) {
    color: var(--color-muted) !important;
  }
  /* The yellow highlight band is fine, but it needs dark text on it for
     contrast in dark mode (Pagefind defaults to yellow bg + inherited fg). */
  :global(#pagefind-search mark) {
    background: #fde68a !important;
    color: #111 !important;
  }
</style>
