---
import FormattedDate from "./FormattedDate.astro";
import { getLinkableTags } from "../utils/tags";
import { categoryLabel } from "../utils/categories";

export interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  heroImage?: string;
  heroImageAlt?: string;
  /** "featured" = large hero card; "compact" = small grid card. */
  variant?: "featured" | "compact";
}

const {
  href,
  title,
  description,
  pubDate,
  category,
  tags,
  heroImage,
  heroImageAlt,
  variant = "compact",
} = Astro.props;
const linkable = await getLinkableTags();
---

<article class={`post-card post-card-${variant}`}>
  {heroImage && (
    <a class="post-card-thumb-link" href={href} aria-hidden="true" tabindex="-1">
      <img
        class="post-card-thumb"
        src={heroImage}
        alt={heroImageAlt ?? ""}
        loading={variant === "featured" ? "eager" : "lazy"}
        decoding="async"
      />
    </a>
  )}
  <div class="post-card-body">
    <a class="category-pill" href={`/categories/${category}/`}>{categoryLabel(category)}</a>
    <h2><a class="post-title" href={href}>{title}</a></h2>
    <p class="post-meta"><FormattedDate date={pubDate} /></p>
    {description && <p class="post-card-desc">{description}</p>}
    {variant === "featured" && tags.length > 0 && (
      <p>
        {tags.slice(0, 6).map((t) =>
          linkable.has(t)
            ? <a class="tag" href={`/tags/${t}/`}>{t}</a>
            : <span class="tag">{t}</span>
        )}
      </p>
    )}
  </div>
</article>
