---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Richard A. Wilson.">
  <h1>About</h1>
  <figure class="about-photo">
    <img
      src="/about/wilson-family.jpg"
      alt="The Wilson family"
      width="600"
      loading="eager"
      decoding="async"
    />
    <figcaption>The Wilsons</figcaption>
  </figure>
  <p>
    I'm Rick Wilson — a Principal Consultant at Microsoft focusing on Power
    Platform and AI. I've been blogging since 2009 (yes, really).
  </p>
  <p>Topics here, roughly in order of frequency:</p>
  <ul>
    <li><strong>Power Platform</strong> — Power Apps, PCF controls, Dataverse,
      Power Automate, governance.</li>
    <li><strong>AI</strong> — tooling, agents, automation, MCP, and the stuff I'm
      currently breaking.</li>
    <li><strong>Electronics & side projects</strong> — occasional weekend
      tinkering.</li>
    <li><strong>3D printing</strong> — builds, mods, and the occasional
      filament disaster.</li>
  </ul>
  <p>
    Find me on
    <a href="https://github.com/rwilson504" target="_blank" rel="noopener noreferrer">GitHub</a> ·
    <a href="https://www.youtube.com/channel/UCdI64e7AJNaLF-b9uCGXLSQ" target="_blank" rel="noopener noreferrer">YouTube</a> ·
    <a href="https://www.linkedin.com/in/rickawilson/">LinkedIn</a>.
  </p>
</BaseLayout>

<style>
  .about-photo {
    margin: 1.5rem 0 2rem;
    max-width: 32rem;
  }
  .about-photo img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  .about-photo figcaption {
    margin-top: 0.5rem;
    font-size: 0.9em;
    color: #666;
    font-style: italic;
  }
</style>
