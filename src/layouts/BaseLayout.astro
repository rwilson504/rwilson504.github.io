---
import { SEO } from "astro-seo";
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  title: string;
  description?: string;
  canonical?: URL | string;
  ogImage?: string;
  /** Use the wider page max-width (for index/listing pages). */
  wide?: boolean;
  /** Article-specific OG tags. */
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
}

const {
  title,
  description = "Tips, tricks, and notes from Richard A. Wilson on Power Platform, AI, and side projects.",
  canonical,
  ogImage,
  wide = false,
  article,
} = Astro.props;

const siteName = "Richard A. Wilson";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const resolvedCanonical = canonical ?? Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <!-- Apply theme BEFORE first paint to avoid flash-of-wrong-theme. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var theme = saved === "light" || saved === "dark" ? saved : "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <meta name="theme-color" content="#15161a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fdfdfc" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={new URL("/rss.xml", Astro.site)}
    />
    <SEO
      title={fullTitle}
      description={description}
      canonical={String(resolvedCanonical)}
      openGraph={{
        basic: {
          title: fullTitle,
          type: article ? "article" : "website",
          image: ogImage ?? new URL("/og-default.png", Astro.site).toString(),
          url: String(resolvedCanonical),
        },
        optional: {
          siteName,
          description,
        },
        article: article
          ? {
              publishedTime: article.publishedTime,
              modifiedTime: article.modifiedTime,
              tags: article.tags,
            }
          : undefined,
      }}
      twitter={{
        card: "summary_large_image",
      }}
    />
  </head>
  <body>
    <SiteHeader />
    <main class={wide ? "wide" : undefined}><slot /></main>
    <SiteFooter />
    <!-- Buy Me a Coffee floating widget -->
    <script
      is:inline
      data-name="BMC-Widget"
      data-cfasync="false"
      src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"
      data-id="richardawilson"
      data-description="Support me on Buy me a coffee!"
      data-message="Help me build more community tools ✨"
      data-color="#FF5F5F"
      data-position="Right"
      data-x_margin="18"
      data-y_margin="18"
    ></script>
  </body>
</html>
